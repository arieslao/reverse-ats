{
  "name": "reverse-ats-ingest",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker: centralized scrape ingest + AI preprocessing for Reverse ATS",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:migrate:local": "wrangler d1 migrations apply reverse-ats-jobs --local",
    "db:migrate:remote": "wrangler d1 migrations apply reverse-ats-jobs --remote",
    "db:console": "wrangler d1 execute reverse-ats-jobs --remote --command"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240419.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.50.0"
  }
}
